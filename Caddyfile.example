# DNS (name.com): A record host "samplesite" -> your public IP
# Merge into your Caddyfile, then: caddy validate && systemctl reload caddy

samplesite.joshuapastizzo.com {
	root * /home/YOUR_USER/repos/235_electric_sample_site
	file_server
	try_files {path} {path}/ {path}/index.html
}

# Replace YOUR_USER with your Linux username (~/repos/235_electric_sample_site).
