# DNS (name.com): A record host "samplesite" -> your public IP
# Merge into your Caddyfile, then: caddy validate && systemctl reload caddy

samplesite.joshuapastizzo.com {
	root * /home/YOUR_USER/repos/235_electric_sample_site

	# Clean URLs: /about -> about/index.html (do not use try_files on /; it can return an empty body)
	@pages path /about /customers /investors /contact
	rewrite @pages {path}/index.html

	file_server
}

# Replace YOUR_USER with your Linux username.
